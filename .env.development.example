# 이 파일을 복사해 `.env.development.local`로 두면 로컬에만 적용됩니다 (git 무시).

# 개발 전용 로그인 백도어 끄기 (실제 /api/v1/auth/login 만 사용)
# REACT_APP_DEV_LOGIN_BYPASS=0

# 백도어 계정 덮어쓰기 (기본: dev@bander.local / bander-dev-2024)
# REACT_APP_DEV_LOGIN_EMAIL=you@example.com
# REACT_APP_DEV_LOGIN_PASSWORD=your-local-secret

# 카카오 로그인은 REST API 키, 카카오맵은 JavaScript 키를 사용합니다.
# REACT_APP_KAKAO_REST_API_KEY=
# REACT_APP_KAKAO_JAVASCRIPT_KEY=

# 프로덕션 빌드용 — 호스팅(Vercel 등) 환경변수 UI에 동일 키로 등록.
# 로컬에서 production 모드 테스트: `.env.production.local` (git 무시)

REACT_APP_API_BASE_URL=
REACT_APP_GATEWAY_AUTH_TOKEN=

REACT_APP_TOSS_CLIENT_KEY=
REACT_APP_GOOGLE_MAPS_API_KEY=

REACT_APP_KAKAO_JAVASCRIPT_KEY=
REACT_APP_GOOGLE_OAUTH_CLIENT_ID=
REACT_APP_APPLE_CLIENT_ID=

REACT_APP_SENTRY_DSN=

# 프로덕션에서는 dev 백도어 미사용 — 아래는 비우거나 설정하지 않음
# REACT_APP_DEV_LOGIN_BYPASS=
# REACT_APP_DEV_LOGIN_EMAIL=
# REACT_APP_DEV_LOGIN_PASSWORD=
